# Copy to .env and fill in values. Never commit .env.

# PostgreSQL (Neon recommended) — use a NEW database for comms (not the PM DB)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# JWT sessions (32+ chars). Can match PM AUTH_SECRET if you want shared session secret,
# but cookies are separate per domain.
AUTH_SECRET="replace-with-long-random-string"

# Production URL of the winning / your PM platform (deep links in messages)
PM_PLATFORM_URL="https://pm-raven-dubgub.vercel.app"
